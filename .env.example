# Скопируйте этот файл в .env.local (для разработки) или .env (для продакшена)
# и заполните своими значениями.

# --- Доступ в админку (загрузка Excel) ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=changeme123
# Секрет для подписи сессии админа — задайте длинную случайную строку
ADMIN_JWT_SECRET=замените-на-длинную-случайную-строку

# --- Telegram-бот для уведомлений о заказах ---
# 1. Напишите @BotFather в Telegram, создайте бота командой /newbot, получите токен
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# 2. Узнайте свой chat_id: напишите боту любое сообщение, затем откройте в браузере
#    https://api.telegram.org/bot<ВАШ_ТОКЕН>/getUpdates
#    и найдите "chat":{"id": ЧИСЛО, ...} — это и есть ваш TELEGRAM_CHAT_ID
TELEGRAM_CHAT_ID=123456789
